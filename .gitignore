# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# persisted dashboard store (machine-specific, do not commit)
/data/
prisma/dev.db
dev.db
dev.db-journal

# Auto-generated VBS files
start.vbs
start-server.vbs
start-lively.vbs

# User uploaded media
public/thumbnails/*
!public/thumbnails/.gitkeep

public/wallpapers/*
!public/wallpapers/itachi-uchiha.png
!public/wallpapers/kakashi.mp4
!public/wallpapers/kakashi2.mp4
!public/wallpapers/kakashi3.png
!public/wallpapers/kakashiChild.jpg
!public/wallpapers/naruto.webp
!public/wallpapers/RockLee.mp4
!public/wallpapers/squa7.jpg
!public/wallpapers/demonslayer1.mp4

# Zips and archives
*.zip
